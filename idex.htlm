<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CadastroUsuario</title>

    <style>
        body{
            background-color: rgb(86, 196, 216);
            font-family: Cambria, Cochin, Georgia, Times, 'Times New Roman', serif;
            margin: 0;
            text-align: center;
            
        }  

    div{
        margin-bottom: 15px;
    }

    </style>
</head>
<body>


    <h2>Cadastro Usuario</h2>
    <form action="">
        

        
        <div>
            <label for="nome">Nome: </label>
            <input type="text" name="nome" id="nome"
            placeholder="Digite Seu Nome" required>
        </div>
        <div>
            <label for="email">Email:</label>
            <input type="email" name="email" id=""
            placeholder="Digite Seu Email" required>
        </div>
        <div>
            <label for="senha">Senha:</label>
            <input type="password" name="senha" id="senha:"
            placeholder="Digite Sua Senha" required>
        </div>
        <div>
            <label for="tel">Telelfone:</label>
            <input type="tel" name="tel" id="tel"
            placeholder="(44) 2070-2070" required> 
        </div>
        <div>
            <label for="dataDeNascimento">Data de Nascimento</label>
            <input type="date" >
        </div>
        <div>
            
            <input type="radio" name="genero" id="fem" value="feminino" required>
            <label for="fem">Feminino</label>
            <input type="radio" name="genero" id="mas" value="masculino" required>
            <label for="mas">Masculino</label>


        </div>
        <button type="submit">Cadastrar</button>
    </form>
 
</body>
</html>
